# Smart Writer Stack - Environment Variables
# Copy this to .env and fill in your keys. NEVER commit .env to GitHub!

# REQUIRED: Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: Override default model
# GEMINI_MODEL=gemini-1.5-flash
